@page "/housing-units"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Smještajne jedinice</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Smještajne jedinice</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Ovdje se prikazuje pregled svih smještajnih jedinica u azilu: bokseva, soba i prostora u kojima se životinje nalaze.
</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupno jedinica</MudText>
            <MudText Typo="Typo.h5">@TotalUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Aktivne jedinice</MudText>
            <MudText Typo="Typo.h5">@ActiveUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Pune jedinice</MudText>
            <MudText Typo="Typo.h5">@FullUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Slobodni kapacitet</MudText>
            <MudText Typo="Typo.h5">@TotalFreeCapacity</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@ShowAll">Sve</MudButton>
    <MudButton OnClick="@ShowActive">Aktivne</MudButton>
    <MudButton OnClick="@ShowFull">Pune</MudButton>
    <MudButton OnClick="@ShowFree">Slobodno</MudButton>
</MudButtonGroup>

<MudTable Items="@FilteredHousingUnits" Hover="true" Striped="true" Bordered="true" Dense="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Naziv</MudTh>
        <MudTh>Tip</MudTh>
        <MudTh>Kapacitet</MudTh>
        <MudTh>Zauzeto</MudTh>
        <MudTh>Slobodno</MudTh>
        <MudTh>Zadnje čišćenje</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl" Alt="@context.Name" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Naziv">@context.Name</MudTd>
        <MudTd DataLabel="Tip">@context.Type</MudTd>
        <MudTd DataLabel="Kapacitet">@context.Capacity</MudTd>
        <MudTd DataLabel="Zauzeto">@context.Occupied</MudTd>
        <MudTd DataLabel="Slobodno">@GetFreeCapacity(context)</MudTd>
        <MudTd DataLabel="Zadnje čišćenje">@GetCleaningDateText(context)</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@GetUnitStatusColor(context)"
                     Variant="Variant.Filled">
                @GetUnitStatusText(context)
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private string selectedHousingFilter = "Sve";

    private List<AzilEdu.Shared.Models.HousingUnit> housingUnits = new();

    protected override async Task OnInitializedAsync()
    {
        List<AzilEdu.Shared.Models.HousingUnit>? result =
            await Http.GetFromJsonAsync<List<AzilEdu.Shared.Models.HousingUnit>>("api/housingunits");
        housingUnits = result ?? new List<AzilEdu.Shared.Models.HousingUnit>();
    }

    private int TotalUnits => housingUnits.Count;
    private int ActiveUnits => housingUnits.Count(u => u.IsActive);
    private int FullUnits => housingUnits.Count(u => u.IsActive && GetFreeCapacity(u) == 0);
    private int TotalFreeCapacity => housingUnits.Where(u => u.IsActive).Sum(u => GetFreeCapacity(u));

    private IEnumerable<AzilEdu.Shared.Models.HousingUnit> FilteredHousingUnits
    {
        get
        {
            return selectedHousingFilter switch
            {
                "Aktivne" => housingUnits.Where(u => u.IsActive).ToList(),
                "Pune" => housingUnits.Where(u => u.IsActive && GetFreeCapacity(u) == 0).ToList(),
                "Slobodno" => housingUnits.Where(u => u.IsActive && GetFreeCapacity(u) > 0).ToList(),
                _ => housingUnits
            };
        }
    }

    private void ShowAll() => selectedHousingFilter = "Sve";
    private void ShowActive() => selectedHousingFilter = "Aktivne";
    private void ShowFull() => selectedHousingFilter = "Pune";
    private void ShowFree() => selectedHousingFilter = "Slobodno";

    private int GetFreeCapacity(AzilEdu.Shared.Models.HousingUnit unit)
    {
        return unit.Capacity - unit.Occupied;
    }

    private string GetCleaningDateText(AzilEdu.Shared.Models.HousingUnit unit)
    {
        if (unit.LastCleanedAt.HasValue)
        {
            return unit.LastCleanedAt.Value.ToShortDateString();
        }
        return "Nije uneseno";
    }

    private string GetUnitStatusText(AzilEdu.Shared.Models.HousingUnit unit)
    {
        if (!unit.IsActive) return "Neaktivno";
        if (unit.Occupied >= unit.Capacity) return "Puno";
        return "Slobodno";
    }

    private Color GetUnitStatusColor(AzilEdu.Shared.Models.HousingUnit unit)
    {
        if (!unit.IsActive) return Color.Default;
        if (unit.Occupied >= unit.Capacity) return Color.Error;
        return Color.Success;
    }
}