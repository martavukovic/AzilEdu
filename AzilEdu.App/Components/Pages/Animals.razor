@page "/animals"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Životinje</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Ovo je početna stranica modula za životinje. U sljedećoj lekciji ovdje ćemo dodati model
    <strong>Animal</strong>, probne podatke i tablični prikaz.
</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">Popis životinja</MudText>
            <MudText Typo="Typo.body2">Ovdje će se prikazivati životinje koje se nalaze u azilu.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">Status</MudText>
            <MudText Typo="Typo.body2">Kasnije ćemo razlikovati životinje koje su u azilu i udomljene životinje.</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6">Slike</MudText>
            <MudText Typo="Typo.body2">Modul će koristiti slike iz foldera <code>wwwroot/images/animals</code>.</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
<hr />

<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@ShowAllAnimals">Sve</MudButton>
    <MudButton OnClick="@ShowAnimalsInShelter">U azilu</MudButton>
    <MudButton OnClick="@ShowAdoptedAnimals">Udomljene</MudButton>
</MudButtonGroup>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupno životinja</MudText>
            <MudText Typo="Typo.h5">@TotalAnimals</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">U azilu</MudText>
            <MudText Typo="Typo.h5">@AvailableAnimals</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Udomljene</MudText>
            <MudText Typo="Typo.h5">@AdoptedAnimals</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudTable Items="@FilteredAnimals" Hover="true" Striped="true" Bordered="true" Dense="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Ime</MudTh>
        <MudTh>Vrsta</MudTh>
        <MudTh>Pasmina</MudTh>
        <MudTh>Spol</MudTh>
        <MudTh>Starost</MudTh>
        <MudTh>Datum dolaska</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl" Alt="@context.Name" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Ime">@context.Name</MudTd>
        <MudTd DataLabel="Vrsta">@context.Species</MudTd>
        <MudTd DataLabel="Pasmina">@context.Breed</MudTd>
        <MudTd DataLabel="Spol">@context.Gender</MudTd>
        <MudTd DataLabel="Starost">@GetAgeText(context) </MudTd>
        <MudTd DataLabel="Datum dolaska">@GetArrivalDateText(context)</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Color="@(context.IsAdopted? Color.Success: Color.Info)" Variant="Variant.Filled">
                @GetAdoptionStatusText(context)
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private int TotalAnimals => animals.Count;
    private int AdoptedAnimals => animals.Count(a => a.IsAdopted);
    private int AvailableAnimals => animals.Count(a => !a.IsAdopted);

    private string selectedStatus = "Sve";

    private IEnumerable<Animal> FilteredAnimals =>
    selectedStatus switch
    {
        "U azilu" => animals.Where(animal => !animal.IsAdopted),
        "Udomljene" => animals.Where(animal => animal.IsAdopted),
        _ => animals
    };

    private void ShowAllAnimals()
    {
        selectedStatus = "Sve";
    }
 
    private void ShowAnimalsInShelter()
    {
        selectedStatus = "U azilu";
    }
 
    private void ShowAdoptedAnimals()
    {
        selectedStatus = "Udomljene";
    }

    private string GetAdoptionStatusText(Animal animal)
    {
        return animal.IsAdopted ? "Udomljena" : "U azilu";
    }

    private string GetAgeText(Animal animal)
    {
        if (animal.Age.HasValue)
        {
            return $"{animal.Age.Value} god.";
        }

        return "Nepoznato";
    }

    private string GetArrivalDateText(Animal animal)
    {
        if (animal.ArrivalDate.HasValue)
        {
            return animal.ArrivalDate.Value.ToShortDateString();
        }

        return "Nije uneseno";
    }

    private List<Animal> animals = new();

    protected override async Task OnInitializedAsync()
    {
        List<Animal>? result = await Http.GetFromJsonAsync<List<Animal>>("api/animals");
        animals = result ?? new List<Animal>();
    }
}