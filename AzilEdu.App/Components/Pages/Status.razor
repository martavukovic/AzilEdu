@page "/status"
@using MudBlazor
@rendermode InteractiveServer
 
<MudButton Color="Color.Primary">Spremi</MudButton>
<MudText Typo="Typo.h4">Species</MudText>
<MudText Typo="Typo.subtitle1">Subtitle1</MudText>
<MudText Typo="Typo.subtitle2">Subtitle2</MudText>
<MudText Typo="Typo.caption">Caption</MudText>

<MudStack Spacing="1">
	<MudText Typo="Typo.h5" Color="Color.Primary">Animals</MudText>
	<MudText Typo="Typo.h6" Color="Color.Success">Podaci su uspješno spremljeni</MudText>
	<MudText Typo="Typo.body2" Color="Color.Error">Došlo je do greške</MudText>
</MudStack>

<MudText Typo="Typo.h4" GutterBottom="true">
	Species
</MudText>

<MudText Typo="Typo.body1" Align="Align.Center">
	Dobro došli u AzilEdu
</MudText>

<MudPaper Class="pa-4">
	<MudText Typo="Typo.h5">Animals</MudText>
	<MudText Typo="Typo.body2">Pregled životinja u azilu.</MudText>
</MudPaper>

<MudGrid>
	<MudItem xs="12" md="6">
		<MudPaper Class="pa-4">Animals</MudPaper>
	</MudItem>
	<MudItem xs="12" md="6">
		<MudPaper Class="pa-4">Species</MudPaper>
	</MudItem>
</MudGrid>

<MudGrid>
	<MudItem xs="12" md="4">
		<MudPaper Class="pa-4">Animals</MudPaper>
	</MudItem>
	<MudItem xs="12" md="4">
		<MudPaper Class="pa-4">Species</MudPaper>
	</MudItem>
	<MudItem xs="12" md="4">
		<MudPaper Class="pa-4">Adopters</MudPaper>
	</MudItem>
</MudGrid>

<MudGrid>
	<MudItem xs="12" md="8">
		<MudPaper Class="pa-4">Glavni sadržaj</MudPaper>
	</MudItem>
	<MudItem xs="12" md="4">
		<MudPaper Class="pa-4">Bočni sadržaj</MudPaper>
	</MudItem>
</MudGrid>

<MudStack Row="true" Spacing="2">
	<MudButton Variant="Variant.Filled" Color="Color.Primary">
		Add Species
	</MudButton>

	<MudButton Variant="Variant.Outlined" Color="Color.Secondary">
		Pregled vrsta
	</MudButton>

	<MudButton Variant="Variant.Text" Color="Color.Info">
		Saznaj više
	</MudButton>

	<MudButton Variant="Variant.Filled"
			   Color="Color.Success"
			   Size="Size.Large"
			   StartIcon="@Icons.Material.Filled.Check">
		Spremi
	</MudButton>
</MudStack>

